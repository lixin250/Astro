---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="颜色转换工具">
<h1>颜色转换工具</h1>
<p style="color: #94a3b8; margin-bottom: 2rem;">支持 Hex / RGB / HSV 互转，多语言代码一键复制。</p>

<div style="display: grid; grid-template-columns: 200px 1fr; gap: 2rem; margin-bottom: 2rem;">
  <div>
    <div id="preview" style="width: 100%; height: 150px; background: #38bdf8; margin-bottom: 1rem; border-radius: 8px;"></div>
    <input type="color" id="picker" value="#38bdf8" style="width: 100%; height: 50px; border: none; cursor: pointer;">
  </div>
  <div>
    <div style="margin-bottom: 1rem;">
      <label>Hex:</label>
      <input type="text" id="hexValue" value="#38bdf8" style="width: 100%; padding: 0.75rem; background: #1e293b; color: white; border: 1px solid #334155; border-radius: 6px; font-family: monospace;">
    </div>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem;">
      <div>
        <label>R:</label>
        <input type="number" id="rValue" min="0" max="255" value="56" style="width: 100%; padding: 0.5rem; background: #1e293b; color: white; border: 1px solid #334155; border-radius: 4px;">
      </div>
      <div>
        <label>G:</label>
        <input type="number" id="gValue" min="0" max="255" value="189" style="width: 100%; padding: 0.5rem; background: #1e293b; color: white; border: 1px solid #334155; border-radius: 4px;">
      </div>
      <div>
        <label>B:</label>
        <input type="number" id="bValue" min="0" max="255" value="248" style="width: 100%; padding: 0.5rem; background: #1e293b; color: white; border: 1px solid #334155; border-radius: 4px;">
      </div>
      <div>
        <label>A:</label>
        <input type="number" id="aValue" min="0" max="255" value="255" style="width: 100%; padding: 0.5rem; background: #1e293b; color: white; border: 1px solid #334155; border-radius: 4px;">
      </div>
    </div>
  </div>
</div>

<h2 style="color: #38bdf8; margin-bottom: 1rem;">Unity C#</h2>
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem;">
  <div style="background: #1e293b; padding: 1rem; border-radius: 8px;">
    <h3 style="color: #A78BFA; margin-bottom: 0.5rem;">Hex 字符串 (C#)</h3>
    <div id="csharpHex" style="background: #0f172a; padding: 0.75rem; border-radius: 6px; font-family: monospace; font-size: 0.8rem; color: #A3E635; word-break: break-all; white-space: pre-line;"></div>
    <button id="copyCsharpHex" style="margin-top: 0.5rem; padding: 0.5rem 1rem; background: #A78BFA; color: white; border: none; border-radius: 4px; cursor: pointer;">复制</button>
  </div>
  <div style="background: #1e293b; padding: 1rem; border-radius: 8px;">
    <h3 style="color: #38BDF8; margin-bottom: 0.5rem;">RGBA 浮点数</h3>
    <div id="csharpRgba" style="background: #0f172a; padding: 0.75rem; border-radius: 6px; font-family: monospace; font-size: 0.85rem; color: #A3E635; word-break: break-all;"></div>
    <button id="copyCsharpRgba" style="margin-top: 0.5rem; padding: 0.5rem 1rem; background: #38BDF8; color: white; border: none; border-radius: 4px; cursor: pointer;">复制</button>
  </div>
  <div style="background: #1e293b; padding: 1rem; border-radius: 8px;">
    <h3 style="color: #22D3EE; margin-bottom: 0.5rem;">Shader (CG/HLSL)</h3>
    <div id="shader" style="background: #0f172a; padding: 0.75rem; border-radius: 6px; font-family: monospace; font-size: 0.85rem; color: #A3E635; word-break: break-all;"></div>
    <button id="copyShader" style="margin-top: 0.5rem; padding: 0.5rem 1rem; background: #22D3EE; color: white; border: none; border-radius: 4px; cursor: pointer;">复制</button>
  </div>
</div>

<h2 style="color: #38bdf8; margin-bottom: 1rem;">其他语言</h2>
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
  <div style="background: #1e293b; padding: 1rem; border-radius: 8px;">
    <h3 style="color: #F472B6; margin-bottom: 0.5rem;">CSS</h3>
    <div id="css" style="background: #0f172a; padding: 0.75rem; border-radius: 6px; font-family: monospace; font-size: 0.85rem; color: #A3E635; word-break: break-all;"></div>
    <button id="copyCss" style="margin-top: 0.5rem; padding: 0.5rem 1rem; background: #F472B6; color: white; border: none; border-radius: 4px; cursor: pointer;">复制</button>
  </div>
  <div style="background: #1e293b; padding: 1rem; border-radius: 8px;">
    <h3 style="color: #FBBF24; margin-bottom: 0.5rem;">JavaScript</h3>
    <div id="javascript" style="background: #0f172a; padding: 0.75rem; border-radius: 6px; font-family: monospace; font-size: 0.85rem; color: #A3E635; word-break: break-all;"></div>
    <button id="copyJs" style="margin-top: 0.5rem; padding: 0.5rem 1rem; background: #FBBF24; color: black; border: none; border-radius: 4px; cursor: pointer;">复制</button>
  </div>
  <div style="background: #1e293b; padding: 1rem; border-radius: 8px;">
    <h3 style="color: #34D399; margin-bottom: 0.5rem;">Python</h3>
    <div id="python" style="background: #0f172a; padding: 0.75rem; border-radius: 6px; font-family: monospace; font-size: 0.85rem; color: #A3E635; word-break: break-all;"></div>
    <button id="copyPython" style="margin-top: 0.5rem; padding: 0.5rem 1rem; background: #34D399; color: black; border: none; border-radius: 4px; cursor: pointer;">复制</button>
  </div>
</div>

<script>
var hexInput = document.getElementById('hexValue');
var rInput = document.getElementById('rValue');
var gInput = document.getElementById('gValue');
var bInput = document.getElementById('bValue');
var aInput = document.getElementById('aValue');
var picker = document.getElementById('picker');
var preview = document.getElementById('preview');

function hexToRgb(hex) {
  return {
    r: parseInt(hex.slice(1, 3), 16),
    g: parseInt(hex.slice(3, 5), 16),
    b: parseInt(hex.slice(5, 7), 16)
  };
}

function rgbToHex(r, g, b) {
  return '#' + [r, g, b].map(function(x) { return Math.max(0, Math.min(255, x)).toString(16).padStart(2, '0'); }).join('');
}

function updateCodeSnippets() {
  var r = parseInt(rInput.value) || 0;
  var g = parseInt(gInput.value) || 0;
  var b = parseInt(bInput.value) || 0;
  var a = parseInt(aInput.value) || 255;
  var hex = hexInput.value.toUpperCase();
  var rf = (r / 255).toFixed(3);
  var gf = (g / 255).toFixed(3);
  var bf = (b / 255).toFixed(3);
  var af = (a / 255).toFixed(3);
  
  document.getElementById('csharpHex').textContent = 
    'Color color;\nif (ColorUtility.TryParseHtmlString(\n  "' + hex + '", out color))\n{\n    // 使用 color\n}';
  document.getElementById('csharpRgba').textContent = 'new Color(' + rf + 'f, ' + gf + 'f, ' + bf + 'f, ' + af + 'f)';
  document.getElementById('shader').textContent = 'fixed4(' + rf + ', ' + gf + ', ' + bf + ', ' + af + ')';
  document.getElementById('css').textContent = hex + Math.round(a * 255 / 255).toString(16).padStart(2, '0');
  document.getElementById('javascript').textContent = 'rgba(' + r + ', ' + g + ', ' + b + ', ' + af + ')';
  document.getElementById('python').textContent = 'Color(' + rf + ', ' + gf + ', ' + bf + ', ' + af + ')';
}

function updateFromHex() {
  var rgb = hexToRgb(hexInput.value);
  rInput.value = rgb.r;
  gInput.value = rgb.g;
  bInput.value = rgb.b;
  picker.value = hexInput.value;
  preview.style.background = hexInput.value;
  updateCodeSnippets();
}

function updateFromRgb() {
  var hex = rgbToHex(parseInt(rInput.value) || 0, parseInt(gInput.value) || 0, parseInt(bInput.value) || 0);
  hexInput.value = hex;
  picker.value = hex;
  preview.style.background = hex;
  updateCodeSnippets();
}

hexInput.addEventListener('input', updateFromHex);
picker.addEventListener('input', function() { hexInput.value = picker.value; updateFromHex(); });
rInput.addEventListener('input', updateFromRgb);
gInput.addEventListener('input', updateFromRgb);
bInput.addEventListener('input', updateFromRgb);
aInput.addEventListener('input', updateCodeSnippets);

document.getElementById('copyCsharpHex').addEventListener('click', function() { navigator.clipboard.writeText(document.getElementById('csharpHex').textContent); });
document.getElementById('copyCsharpRgba').addEventListener('click', function() { navigator.clipboard.writeText(document.getElementById('csharpRgba').textContent); });
document.getElementById('copyShader').addEventListener('click', function() { navigator.clipboard.writeText(document.getElementById('shader').textContent); });
document.getElementById('copyCss').addEventListener('click', function() { navigator.clipboard.writeText(document.getElementById('css').textContent); });
document.getElementById('copyJs').addEventListener('click', function() { navigator.clipboard.writeText(document.getElementById('javascript').textContent); });
document.getElementById('copyPython').addEventListener('click', function() { navigator.clipboard.writeText(document.getElementById('python').textContent); });

updateCodeSnippets();
</script>
</BaseLayout>
