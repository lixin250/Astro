---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="颜色转换">
  <h1 style="margin-bottom: 2rem;">🎨 颜色转换工具</h1>
  
  <div style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155; margin-bottom: 2rem;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
      <div>
        <div id="colorPreview" style="
          width: 100%;
          height: 120px;
          border-radius: 8px;
          margin-bottom: 1rem;
          background: #38bdf8;
        "></div>
        <input type="color" id="colorPicker" value="#38bdf8" style="
          width: 100%;
          height: 40px;
          border: none;
          border-radius: 8px;
          cursor: pointer;
        " />
      </div>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
          <label style="display: block; margin-bottom: 0.5rem; color: #94a3b8;">Hex</label>
          <input type="text" id="hexValue" value="#38bdf8" style="
            width: 100%;
            padding: 0.75rem;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 8px;
            color: #e2e8f0;
            font-family: monospace;
          " />
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;">
          <div>
            <label style="display: block; margin-bottom: 0.25rem; color: #64748b; font-size: 0.75rem;">R</label>
            <input type="number" id="rValue" min="0" max="255" value="56" style="
              width: 100%;
              padding: 0.5rem;
              background: #0f172a;
              border: 1px solid #334155;
              border-radius: 6px;
              color: #e2e8f0;
            " />
          </div>
          <div>
            <label style="display: block; margin-bottom: 0.25rem; color: #64748b; font-size: 0.75rem;">G</label>
            <input type="number" id="gValue" min="0" max="255" value="189" style="
              width: 100%;
              padding: 0.5rem;
              background: #0f172a;
              border: 1px solid #334155;
              border-radius: 6px;
              color: #e2e8f0;
            " />
          </div>
          <div>
            <label style="display: block; margin-bottom: 0.25rem; color: #64748b; font-size: 0.75rem;">B</label>
            <input type="number" id="bValue" min="0" max="255" value="248" style="
              width: 100%;
              padding: 0.5rem;
              background: #0f172a;
              border: 1px solid #334155;
              border-radius: 6px;
              color: #e2e8f0;
            " />
          </div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;">
          <div>
            <label style="display: block; margin-bottom: 0.25rem; color: #64748b; font-size: 0.75rem;">H</label>
            <input type="number" id="hValue" min="0" max="360" value="199" style="
              width: 100%;
              padding: 0.5rem;
              background: #0f172a;
              border: 1px solid #334155;
              border-radius: 6px;
              color: #e2e8f0;
            " />
          </div>
          <div>
            <label style="display: block; margin-bottom: 0.25rem; color: #64748b; font-size: 0.75rem;">S</label>
            <input type="number" id="sValue" min="0" max="100" value="92" style="
              width: 100%;
              padding: 0.5rem;
              background: #0f172a;
              border: 1px solid #334155;
              border-radius: 6px;
              color: #e2e8f0;
            " />
          </div>
          <div>
            <label style="display: block; margin-bottom: 0.25rem; color: #64748b; font-size: 0.75rem;">V</label>
            <input type="number" id="vValue" min="0" max="100" value="97" style="
              width: 100%;
              padding: 0.5rem;
              background: #0f172a;
              border: 1px solid #334155;
              border-radius: 6px;
              color: #e2e8f0;
            " />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155; margin-bottom: 2rem;">
    <h2 style="margin-bottom: 1rem; color: #38bdf8;">Unity C# 代码参考</h2>
    <pre style="background: #0f172a; padding: 1rem; border-radius: 8px; overflow-x: auto; font-size: 0.875rem;"><code>using UnityEngine;

public static class ColorUtils
{
    // Hex → Unity Color
    public static Color HexToColor(string hex)
    {
        Color color;
        if (ColorUtility.TryParseHtmlString(hex, out color))
            return color;
        return Color.white;
    }
    
    // Color → Hex
    public static string ColorToHex(Color color)
    {
        return "#" + ColorUtility.ToHtmlStringRGB(color);
    }
    
    // RGB → HSV
    public static void RGBtoHSV(Color color, out float h, out float s, out float v)
    {
        float max = Mathf.Max(color.r, color.g, color.b);
        float min = Mathf.Min(color.r, color.g, color.b);
        float delta = max - min;
        
        v = max;
        s = max == 0 ? 0 : delta / max;
        
        if (delta == 0) h = 0;
        else if (max == color.r) h = 60 * (((color.g - color.b) / delta) % 6);
        else if (max == color.g) h = 60 * (((color.b - color.r) / delta) + 2);
        else h = 60 * (((color.r - color.g) / delta) + 4);
        
        if (h < 0) h += 360;
    }
    
    // HSV → RGB
    public static Color HSVtoRGB(float h, float s, float v)
    {
        float c = v * s;
        float x = c * (1 - Mathf.Abs((h / 60) % 2 - 1));
        float m = v - c;
        
        Vector3 rgb;
        if (h < 60) rgb = new Vector3(c, x, 0);
        else if (h < 120) rgb = new Vector3(x, c, 0);
        else if (h < 180) rgb = new Vector3(0, c, x);
        else if (h < 240) rgb = new Vector3(0, x, c);
        else if (h < 300) rgb = new Vector3(x, 0, c);
        else rgb = new Vector3(c, 0, x);
        
        return new Color(rgb.x + m, rgb.y + m, rgb.z + m);
    }
}

// 使用示例
Color myColor = ColorUtils.HexToColor("#38BDF8");
float h, s, v;
ColorUtils.RGBtoHSV(myColor, out h, out s, out v);
string hex = ColorUtils.ColorToHex(myColor);</code></pre>
  </div>

  <div style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155;">
    <h2 style="margin-bottom: 1rem; color: #38bdf8;">预设颜色</h2>
    <div id="presets" style="display: flex; flex-wrap: wrap; gap: 0.5rem;"></div>
  </div>

  <script>
    const hexInput = document.getElementById('hexValue') as HTMLInputElement;
    const rInput = document.getElementById('rValue') as HTMLInputElement;
    const gInput = document.getElementById('gValue') as HTMLInputElement;
    const bInput = document.getElementById('bValue') as HTMLInputElement;
    const hInput = document.getElementById('hValue') as HTMLInputElement;
    const sInput = document.getElementById('sValue') as HTMLInputElement;
    const vInput = document.getElementById('vValue') as HTMLInputElement;
    const picker = document.getElementById('colorPicker') as HTMLInputElement;
    const preview = document.getElementById('colorPreview');

    const presets = [
      '#F87171', '#FB923C', '#FBBF24', '#A3E635', '#34D399',
      '#22D3EE', '#38BDF8', '#818CF8', '#A78BFA', '#F472B6',
      '#FFFFFF', '#E2E8F0', '#94A3B8', '#64748B', '#334155', '#1E293B', '#0F172A', '#000000'
    ];

    presets.forEach(color => {
      const btn = document.createElement('button');
      btn.style.cssText = `
        width: 32px; height: 32px; border-radius: 6px;
        background: ${color}; border: 2px solid transparent;
        cursor: pointer;
      `;
      btn.onclick = () => setColor(color);
      document.getElementById('presets').appendChild(btn);
    });

    function hexToRgb(hex: string) {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return { r, g, b };
    }

    function rgbToHex(r: number, g: number, b: number) {
      return '#' + [r, g, b].map(x => x.toString(16).padStart(2, '0')).join('');
    }

    function rgbToHsv(r: number, g: number, b: number) {
      r /= 255; g /= 255; b /= 255;
      const max = Math.max(r, g, b), min = Math.min(r, g, b);
      const v = max, d = max - min;
      const s = max === 0 ? 0 : d / max;
      let h = 0;
      if (max !== min) {
        if (max === r) h = 60 * (((g - b) / d) % 6);
        else if (max === g) h = 60 * ((b - r) / d + 2);
        else h = 60 * ((r - g) / d + 4);
        if (h < 0) h += 360;
      }
      return { h: Math.round(h), s: Math.round(s * 100), v: Math.round(v * 100) };
    }

    function hsvToRgb(h: number, s: number, v: number) {
      s /= 100; v /= 100;
      const c = v * s;
      const x = c * (1 - Math.abs((h / 60) % 2 - 1));
      const m = v - c;
      let r = 0, g = 0, b = 0;
      if (h < 60) { r = c; g = x; }
      else if (h < 120) { r = x; g = c; }
      else if (h < 180) { g = c; b = x; }
      else if (h < 240) { g = x; b = c; }
      else if (h < 300) { r = x; b = c; }
      else { r = c; b = x; }
      return {
        r: Math.round((r + m) * 255),
        g: Math.round((g + m) * 255),
        b: Math.round((b + m) * 255)
      };
    }

    function setColor(hex: string) {
      const rgb = hexToRgb(hex);
      const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
      
      hexInput.value = hex;
      rInput.value = rgb.r.toString();
      gInput.value = rgb.g.toString();
      bInput.value = rgb.b.toString();
      hInput.value = hsv.h.toString();
      sInput.value = hsv.s.toString();
      vInput.value = hsv.v.toString();
      picker.value = hex;
      updatePreview();
    }

    function updatePreview() {
      preview.style.background = hexInput.value;
      picker.value = hexInput.value;
    }

    function updateFromRgb() {
      const r = parseInt(rInput.value) || 0;
      const g = parseInt(gInput.value) || 0;
      const b = parseInt(bInput.value) || 0;
      const hex = rgbToHex(r, g, b);
      const hsv = rgbToHsv(r, g, b);
      hexInput.value = hex;
      hInput.value = hsv.h.toString();
      sInput.value = hsv.s.toString();
      vInput.value = hsv.v.toString();
      updatePreview();
    }

    function updateFromHsv() {
      const h = parseInt(hInput.value) || 0;
      const s = parseInt(sInput.value) || 0;
      const v = parseInt(vInput.value) || 0;
      const rgb = hsvToRgb(h, s, v);
      const hex = rgbToHex(rgb.r, rgb.g, rgb.b);
      hexInput.value = hex;
      rInput.value = rgb.r.toString();
      gInput.value = rgb.g.toString();
      bInput.value = rgb.b.toString();
      updatePreview();
    }

    hexInput.addEventListener('input', () => {
      if (/^#[0-9A-Fa-f]{6}$/.test(hexInput.value)) {
        const rgb = hexToRgb(hexInput.value);
        const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
        rInput.value = rgb.r.toString();
        gInput.value = rgb.g.toString();
        bInput.value = rgb.b.toString();
        hInput.value = hsv.h.toString();
        sInput.value = hsv.s.toString();
        vInput.value = hsv.v.toString();
        updatePreview();
      }
    });

    picker.addEventListener('input', () => setColor(picker.value));
    [rInput, gInput, bInput].forEach(i => i.addEventListener('input', updateFromRgb));
    [hInput, sInput, vInput].forEach(i => i.addEventListener('input', updateFromHsv));
  </script>
</BaseLayout>
