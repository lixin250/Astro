---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tween 缓动函数可视化">
<h1>Tween 缓动函数可视化</h1>
<p style="color: #94a3b8; margin-bottom: 2rem;">Unity 游戏开发中常用的缓动函数，点击卡片可查看动画演示。</p>

<div id="curvesGrid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;"></div>

<div style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155; margin-top: 2rem; margin-bottom: 2rem;">
  <h2 style="color: #38bdf8; margin-bottom: 1rem;">缓动函数特性说明</h2>
  <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
    <div style="background: #0f172a; padding: 1rem; border-radius: 8px;">
      <h3 style="color: #F87171;">Ease In（渐进）</h3>
      <p style="color: #94a3b8; font-size: 0.9rem;">开始慢，结束快。适合物体进入场景、从高处落下等。让动画有重量感，自然减速。</p>
    </div>
    <div style="background: #0f172a; padding: 1rem; border-radius: 8px;">
      <h3 style="color: #34D399;">Ease Out（渐出）</h3>
      <p style="color: #94a3b8; font-size: 0.9rem;">开始快，结束慢。适合物体弹出、弹框出现、UI 元素进入。最常用的缓动效果。</p>
    </div>
    <div style="background: #0f172a; padding: 1rem; border-radius: 8px;">
      <h3 style="color: #38BDF8;">Ease InOut（渐进渐出）</h3>
      <p style="color: #94a3b8; font-size: 0.9rem;">两头慢，中间快。适合开关动画、门扉开启、进度条填充。有明显的起承转合。</p>
    </div>
    <div style="background: #0f172a; padding: 1rem; border-radius: 8px;">
      <h3 style="color: #F472B6;">Bounce / Back（弹跳/回弹）</h3>
      <p style="color: #94a3b8; font-size: 0.9rem;">会超过目标值后回弹。适合收集物拾取，金币飞入，菜单弹出。增加活泼感。</p>
    </div>
  </div>
</div>

<div style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155; margin-bottom: 2rem;">
  <h2 style="color: #38bdf8; margin-bottom: 1rem;">PrimeTween vs 其他 Tween 库对比</h2>
  <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
    <thead>
      <tr style="border-bottom: 1px solid #334155;">
        <th style="text-align: left; padding: 0.75rem; color: #f1f5f9;">特性</th>
        <th style="text-align: center; padding: 0.75rem; color: #34D399;">PrimeTween</th>
        <th style="text-align: center; padding: 0.75rem; color: #FBBF24;">DOTween</th>
        <th style="text-align: center; padding: 0.75rem; color: #F87171;">LeanTween</th>
      </tr>
    </thead>
    <tbody style="color: #94a3b8;">
      <tr style="border-bottom: 1px solid #1e293b;">
        <td style="padding: 0.75rem;">GC 分配</td>
        <td style="text-align: center; color: #34D399;">零分配</td>
        <td style="text-align: center;">少量</td>
        <td style="text-align: center;">少量</td>
      </tr>
      <tr style="border-bottom: 1px solid #1e293b;">
        <td style="padding: 0.75rem;">Inspector 支持</td>
        <td style="text-align: center; color: #34D399;">原生支持</td>
        <td style="text-align: center;">需 Pro</td>
        <td style="text-align: center;">有限</td>
      </tr>
      <tr style="border-bottom: 1px solid #1e293b;">
        <td style="padding: 0.75rem;">Shake/Punch</td>
        <td style="text-align: center; color: #34D399;">内置</td>
        <td style="text-align: center;">无</td>
        <td style="text-align: center;">无</td>
      </tr>
      <tr>
        <td style="padding: 0.75rem;">推荐场景</td>
        <td style="text-align: center; font-size: 0.8rem;">移动端/性能敏感</td>
        <td style="text-align: center; font-size: 0.8rem;">大型项目/生态完善</td>
        <td style="text-align: center; font-size: 0.8rem;">简单动画</td>
      </tr>
    </tbody>
  </table>
</div>

<div style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155;">
  <h2 style="color: #38bdf8; margin-bottom: 1rem;">GitHub 项目地址</h2>
  <div style="display: grid; gap: 1rem;">
    <a href="https://github.com/KyryloKuzyk/PrimeTween" target="_blank" style="display: flex; align-items: center; gap: 1rem; background: #0f172a; padding: 1rem; border-radius: 8px; text-decoration: none;">
      <span style="font-size: 2rem;">🎯</span>
      <div>
        <div style="color: #f1f5f9; font-weight: bold;">PrimeTween</div>
        <div style="color: #64748b; font-size: 0.85rem;">github.com/KyryloKuzyk/PrimeTween</div>
      </div>
    </a>
    <a href="https://github.com/Demigod/dotween" target="_blank" style="display: flex; align-items: center; gap: 1rem; background: #0f172a; padding: 1rem; border-radius: 8px; text-decoration: none;">
      <span style="font-size: 2rem;">⚡</span>
      <div>
        <div style="color: #f1f5f9; font-weight: bold;">DOTween</div>
        <div style="color: #64748b; font-size: 0.85rem;">github.com/Demigod/dotween</div>
      </div>
    </a>
  </div>
</div>

<script>
var easings = {
  'Linear': { fn: function(t) { return t; }, color: '#94a3b8', desc: '线性匀速' },
  'EaseInQuad': { fn: function(t) { return t * t; }, color: '#F87171', desc: '二次方缓入' },
  'EaseOutQuad': { fn: function(t) { return t * (2 - t); }, color: '#FB923C', desc: '二次方缓出' },
  'EaseInCubic': { fn: function(t) { return t * t * t; }, color: '#FBBF24', desc: '三次方缓入' },
  'EaseOutCubic': { fn: function(t) { return 1 - Math.pow(1 - t, 3); }, color: '#A3E635', desc: '三次方缓出' },
  'EaseInSine': { fn: function(t) { return 1 - Math.cos(t * Math.PI / 2); }, color: '#34D399', desc: '正弦缓入' },
  'EaseOutSine': { fn: function(t) { return Math.sin(t * Math.PI / 2); }, color: '#22D3EE', desc: '正弦缓出' },
  'EaseInExpo': { fn: function(t) { return t === 0 ? 0 : Math.pow(2, 10 * t - 10); }, color: '#38BDF8', desc: '指数缓入' },
  'EaseOutExpo': { fn: function(t) { return t === 1 ? 1 : 1 - Math.pow(2, -10 * t); }, color: '#818CF8', desc: '指数缓出' },
  'EaseInOutSine': { fn: function(t) { return -(Math.cos(Math.PI * t) - 1) / 2; }, color: '#A78BFA', desc: '正弦缓入缓出' },
  'EaseOutBounce': { fn: function(t) {
    var n1 = 7.5625, d1 = 2.75;
    if (t < 1 / d1) return n1 * t * t;
    if (t < 2 / d1) return n1 * (t -= 1.5 / d1) * t + 0.75;
    if (t < 2.5 / d1) return n1 * (t -= 2.25 / d1) * t + 0.9375;
    return n1 * (t -= 2.625 / d1) * t + 0.984375;
  }, color: '#F472B6', desc: '弹跳出' }
};

var animationIds = {};

function drawCurve(name, showEased) {
  var canvas = document.getElementById('curve_' + name);
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var w = 200, h = 120;
  
  ctx.fillStyle = '#0f172a';
  ctx.fillRect(0, 0, w, h);
  
  ctx.strokeStyle = '#1e293b';
  ctx.lineWidth = 1;
  for (var i = 0; i <= 4; i++) {
    var x = i * (w / 4);
    ctx.beginPath();
    ctx.moveTo(x, 0);
    ctx.lineTo(x, h);
    ctx.stroke();
    var y = i * (h / 4);
    ctx.beginPath();
    ctx.moveTo(0, y);
    ctx.lineTo(w, y);
    ctx.stroke();
  }
  
  if (showEased) {
    ctx.strokeStyle = '#ef4444';
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    for (var i = 0; i <= 50; i++) {
      var t = i / 50;
      var x = t * w;
      var y = h - t * h;
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.stroke();
    ctx.setLineDash([]);
  }
  
  var data = easings[name];
  ctx.strokeStyle = data.color;
  ctx.lineWidth = 2;
  ctx.beginPath();
  for (var i = 0; i <= 50; i++) {
    var t = i / 50;
    var x = t * w;
    var y = h - data.fn(t) * h;
    if (i === 0) ctx.moveTo(x, y);
    else ctx.lineTo(x, y);
  }
  ctx.stroke();
  
  ctx.fillStyle = data.color;
  ctx.beginPath();
  ctx.arc(w, h - data.fn(1) * h, 4, 0, Math.PI * 2);
  ctx.fill();
}

function startAnimation(name) {
  if (animationIds[name]) {
    cancelAnimationFrame(animationIds[name]);
  }
  
  var canvas = document.getElementById('curve_' + name);
  var ctx = canvas.getContext('2d');
  var w = 200, h = 120;
  var duration = 1000;
  var startTime = null;
  var data = easings[name];
  
  function animate(timestamp) {
    if (!startTime) startTime = timestamp;
    var elapsed = timestamp - startTime;
    var t = Math.min(elapsed / duration, 1);
    var easedT = data.fn(t);
    
    drawCurve(name, true);
    
    var ballX = easedT * w;
    var ballY = h - easedT * h;
    
    ctx.fillStyle = data.color;
    ctx.beginPath();
    ctx.arc(ballX, ballY, 5, 0, Math.PI * 2);
    ctx.fill();
    
    if (t < 1) {
      animationIds[name] = requestAnimationFrame(animate);
    } else {
      delete animationIds[name];
    }
  }
  
  animationIds[name] = requestAnimationFrame(animate);
}

function createCurvesGrid() {
  var grid = document.getElementById('curvesGrid');
  var index = 0;
  
  for (var name in easings) {
    var data = easings[name];
    var card = document.createElement('div');
    card.style.cssText = 'background: #1e293b; border-radius: 12px; border: 1px solid #334155; padding: 1rem; cursor: pointer; transition: all 0.2s;';
    card.onmouseover = function() { this.style.borderColor = data.color; };
    card.onmouseout = function() { this.style.borderColor = '#334155'; };
    
    var title = document.createElement('h3');
    title.style.cssText = 'color: ' + data.color + '; margin-bottom: 0.5rem; font-size: 0.9rem;';
    title.textContent = name;
    
    var desc = document.createElement('p');
    desc.style.cssText = 'color: #64748b; font-size: 0.75rem; margin-bottom: 0.5rem;';
    desc.textContent = data.desc;
    
    var canvas = document.createElement('canvas');
    canvas.id = 'curve_' + name;
    canvas.width = 200;
    canvas.height = 120;
    canvas.style.cssText = 'width: 100%; border-radius: 8px;';
    
    card.appendChild(title);
    card.appendChild(desc);
    card.appendChild(canvas);
    
    card.addEventListener('click', function(n) {
      return function() { startAnimation(n); };
    }(name));
    
    grid.appendChild(card);
    
    setTimeout(function(n) {
      return function() { drawCurve(n, false); };
    }(name), index * 50);
    
    index++;
  }
}

createCurvesGrid();
</script>
</BaseLayout>
