---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="时间戳转换">
<h1 style="margin-bottom: 2rem;">时间戳转换工具</h1>

<div style="display: grid; gap: 2rem;">
  <section style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155;">
    <h2 style="margin-bottom: 1rem; color: #38bdf8;">Unix 时间戳 与 DateTime 互转</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <div>
        <label style="display: block; margin-bottom: 0.5rem; color: #94a3b8;">Unix 时间戳（秒）</label>
        <input type="number" id="unixSeconds" placeholder="1704067200" style="width: 100%; padding: 0.75rem; background: #0f172a; border: 1px solid #334155; border-radius: 8px; color: #e2e8f0; font-size: 1rem; font-family: monospace;">
        <button id="toDateBtn" style="margin-top: 0.75rem; padding: 0.5rem 1rem; background: #38bdf8; color: #0f172a; border: none; border-radius: 6px; cursor: pointer; font-weight: 600;">转换</button>
      </div>
      <div>
        <label style="display: block; margin-bottom: 0.5rem; color: #94a3b8;">DateTime 字符串</label>
        <input type="text" id="dateString" placeholder="2024-01-01 00:00:00" style="width: 100%; padding: 0.75rem; background: #0f172a; border: 1px solid #334155; border-radius: 8px; color: #e2e8f0; font-size: 1rem; font-family: monospace;">
        <button id="toUnixBtn" style="margin-top: 0.75rem; padding: 0.5rem 1rem; background: #38bdf8; color: #0f172a; border: none; border-radius: 6px; cursor: pointer; font-weight: 600;">转换</button>
      </div>
    </div>
  </section>

  <section style="background: #1e293b; padding: 1.5rem; border-radius: 12px; border: 1px solid #334155;">
    <h2 style="margin-bottom: 1rem; color: #38bdf8;">Unity 常用时间参考</h2>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
      <div style="background: #0f172a; padding: 1rem; border-radius: 8px; text-align: center;">
        <div style="color: #64748b; font-size: 0.75rem;">当前时间戳</div>
        <div id="currentUnix" style="font-size: 1.25rem; font-family: monospace; color: #f1f5f9; margin-top: 0.25rem;"></div>
      </div>
      <div style="background: #0f172a; padding: 1rem; border-radius: 8px; text-align: center;">
        <div style="color: #64748b; font-size: 0.75rem;">毫秒级</div>
        <div id="currentUnixMs" style="font-size: 1.25rem; font-family: monospace; color: #f1f5f9; margin-top: 0.25rem;"></div>
      </div>
      <div style="background: #0f172a; padding: 1rem; border-radius: 8px; text-align: center;">
        <div style="color: #64748b; font-size: 0.75rem;">格式化</div>
        <div id="currentFormatted" style="font-size: 1rem; font-family: monospace; color: #f1f5f9; margin-top: 0.25rem;"></div>
      </div>
    </div>
  </section>
</div>

<script>
document.getElementById('toDateBtn').addEventListener('click', function() {
  var input = document.getElementById('unixSeconds');
  var output = document.getElementById('dateString');
  var timestamp = parseInt(input.value);
  if (!isNaN(timestamp)) {
    var date = new Date(timestamp * 1000);
    output.value = date.toLocaleString('zh-CN');
  }
});

document.getElementById('toUnixBtn').addEventListener('click', function() {
  var input = document.getElementById('dateString');
  var output = document.getElementById('unixSeconds');
  var date = new Date(input.value);
  if (!isNaN(date.getTime())) {
    output.value = Math.floor(date.getTime() / 1000).toString();
  }
});

function updateCurrentTime() {
  var now = new Date();
  var unix = Math.floor(now.getTime() / 1000);
  var unixMs = Math.floor(now.getTime());
  var formatted = now.toLocaleString('zh-CN');
  
  document.getElementById('currentUnix').textContent = unix.toString();
  document.getElementById('currentUnixMs').textContent = unixMs.toString();
  document.getElementById('currentFormatted').textContent = formatted;
}

updateCurrentTime();
setInterval(updateCurrentTime, 1000);
</script>
</BaseLayout>
