---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="JSON Formatter">
<h1>JSON Formatter</h1>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
  <div>
    <div style="display: flex; gap: 0.5rem; margin-bottom: 0.5rem;">
      <button id="formatBtn" style="padding: 0.5rem 1rem; background: #38bdf8; color: #0f172a; border: none; border-radius: 4px; cursor: pointer;">Format</button>
      <button id="minifyBtn" style="padding: 0.5rem 1rem; background: #334155; color: white; border: none; border-radius: 4px; cursor: pointer;">Minify</button>
      <button id="clearBtn" style="padding: 0.5rem 1rem; background: #334155; color: white; border: none; border-radius: 4px; cursor: pointer;">Clear</button>
    </div>
    <textarea id="inputJson" placeholder='{"key": "value"}' style="width: 100%; height: 300px; padding: 1rem; background: #1e293b; color: white; border: 1px solid #334155; border-radius: 8px; font-family: monospace;"></textarea>
  </div>
  <div>
    <div style="display: flex; justify-content: flex-end; margin-bottom: 0.5rem;">
      <button id="copyBtn" style="padding: 0.5rem 1rem; background: #38bdf8; color: #0f172a; border: none; border-radius: 4px; cursor: pointer;">Copy</button>
    </div>
    <textarea id="outputJson" readonly style="width: 100%; height: 300px; padding: 1rem; background: #1e293b; color: #38bdf8; border: 1px solid #334155; border-radius: 8px; font-family: monospace;"></textarea>
  </div>
</div>

<div id="errorBox" style="display: none; background: rgba(248, 113, 113, 0.1); border: 1px solid #F87171; border-radius: 8px; padding: 1rem; margin-top: 1rem;">
  <strong style="color: #F87171;">Error:</strong>
  <span id="errorMessage" style="color: #FCA5A5; font-family: monospace;"></span>
</div>

<script>
var input = document.getElementById('inputJson');
var output = document.getElementById('outputJson');
var errorBox = document.getElementById('errorBox');
var errorMessage = document.getElementById('errorMessage');

function showError(msg) {
  errorMessage.textContent = msg;
  errorBox.style.display = 'block';
  output.value = '';
}

function hideError() {
  errorBox.style.display = 'none';
}

document.getElementById('formatBtn').addEventListener('click', function() {
  hideError();
  try {
    var obj = JSON.parse(input.value);
    output.value = JSON.stringify(obj, null, 2);
  } catch (e) {
    showError(e.message);
  }
});

document.getElementById('minifyBtn').addEventListener('click', function() {
  hideError();
  try {
    var obj = JSON.parse(input.value);
    output.value = JSON.stringify(obj);
  } catch (e) {
    showError(e.message);
  }
});

document.getElementById('clearBtn').addEventListener('click', function() {
  input.value = '';
  output.value = '';
  hideError();
});

document.getElementById('copyBtn').addEventListener('click', function() {
  navigator.clipboard.writeText(output.value);
});
</script>
</BaseLayout>
